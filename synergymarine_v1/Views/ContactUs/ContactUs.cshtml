@{
    ViewData["Title"] = "Contact Us";
}

<style>
    /* ── HERO SECTION ── */
    .cp-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .cp-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/compimg.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .cp-hero:hover .cp-hero-bg {
        transform: scale(1.0);
    }

    .cp-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.75) 100%);
    }

    .cp-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .cp-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

    .cp-hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin: 0;
    }

    /* ── CONTENT SECTION ── */
    .cp-content-wrapper {
        background: #ffffff;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 4rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    .cp-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
        align-items: start;
    }

    .cp-lead-heading {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
        margin-bottom: 1.5rem;
        border-left: 4px solid #dc2626;
        padding-left: 1rem;
    }

    .cp-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.85;
        margin-bottom: 1.25rem;
    }

    .cp-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 1.75rem 0;
    }

    /* Vision / Mission blocks */
    .vm-block {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.5rem;
    }

    .vm-block-icon {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
    }

    .vm-block-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a365d;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .vm-block-title span.badge-label {
            background: #2563eb;
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            border-radius: 4px;
            padding: 0.2rem 0.6rem;
        }

    .vm-block-text {
        font-size: 0.92rem;
        color: #4b5563;
        line-height: 1.85;
        margin: 0;
    }

    /* Contact detail rows */
    .contact-detail-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .contact-detail-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .contact-detail-icon {
        width: 38px;
        height: 38px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .contact-detail-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #9ca3af;
        margin-bottom: 0.2rem;
    }

    .contact-detail-value {
        font-size: 0.9rem;
        color: #1e293b;
        font-weight: 500;
        line-height: 1.5;
    }

        .contact-detail-value a {
            color: #2563eb;
            text-decoration: none;
        }

            .contact-detail-value a:hover {
                text-decoration: underline;
            }

    /* Right: map embed */
    .cp-image-col {
        position: sticky;
        top: 100px;
    }

    .cp-map-frame {
        width: 100%;
        height: 320px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        border: none;
        display: block;
    }

    .cp-img-caption {
        font-size: 12px;
        color: #9ca3af;
        text-align: center;
        margin-top: 0.6rem;
        letter-spacing: 0.3px;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .cp-hero {
            height: 280px;
        }

        .cp-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .cp-image-col {
            position: static;
        }

        .cp-map-frame {
            height: 240px;
        }

        .cp-content-wrapper {
            padding: 2rem 1.25rem 3rem;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="cp-hero">
    <div class="cp-hero-bg"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <p class="cp-breadcrumb">Contact Us</p>
        <h1 class="cp-hero-title">Contact Us</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="cp-content-wrapper">
    <div class="cp-grid">

        <!-- LEFT: Contact Details -->
        <div class="cp-text-col">
            <p class="cp-lead-heading">
                Keep in Touch With Us
            </p>

            <p class="cp-body-text">
                We'd love to hear from you. Whether you have an enquiry about our services, a business proposal, or simply need more information — our team is ready to assist.
            </p>

            <div class="vm-block">
                <ul class="contact-detail-list">

                    <li class="contact-detail-item">
                        <div class="contact-detail-icon">📞</div>
                        <div>
                            <div class="contact-detail-label">Phone</div>
                            <div class="contact-detail-value">
                                <a href="tel:+60355108260" style="color:#dc2626">+603-5510 8260</a> /
                                <a href="tel:+60355108261" style="color:#dc2626">+603-5510 8261</a>
                            </div>
                        </div>
                    </li>

                    <li class="contact-detail-item">
                        <div class="contact-detail-icon">🌐</div>
                        <div>
                            <div class="contact-detail-label">Website</div>
                            <div class="contact-detail-value">
                                <a href="https://www.synergymarine.com.my" style="color:#dc2626" target="_blank" rel="noopener">www.synergymarine.com.my</a>
                            </div>
                        </div>
                    </li>

                    <li class="contact-detail-item">
                        <div class="contact-detail-icon">📍</div>
                        <div>
                            <div class="contact-detail-label">Address</div>
                            <div class="contact-detail-value">
                                No. 21, Jalan Tukul P 15/P, Seksyen 15,<br />
                                40200 Shah Alam, Selangor, Malaysia
                            </div>
                        </div>
                    </li>

                    <li class="contact-detail-item">
                        <div class="contact-detail-icon">🕐</div>
                        <div>
                            <div class="contact-detail-label">Office Hours</div>
                            <div class="contact-detail-value">
                                Monday – Friday: 8:30 AM – 5:30 PM<br />
                                Saturday – Sunday: Closed
                            </div>
                        </div>
                    </li>

                </ul>
            </div>
        </div>

        <!-- RIGHT: Map -->
        <div class="cp-image-col">
            <iframe class="cp-map-frame"
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3984.0!2d101.5270!3d3.0740!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMy4wNzQwLCAxMDEuNTI3MA!5e0!3m2!1sen!2smy!4v1"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Synergy Marine Office Location">
            </iframe>
            <p class="cp-img-caption">No. 21, Jalan Tukul P 15/P, Seksyen 15, Shah Alam</p>
        </div>

    </div>
</div>
