@{
    ViewData["Title"] = "Fleet Overview";
}

<style>
    /* ── HERO SECTION ── */
    .cp-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .cp-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/1.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .cp-hero:hover .cp-hero-bg {
        transform: scale(1.0);
    }

    .cp-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.75) 100%);
    }

    .cp-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .cp-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

    .cp-hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin: 0;
    }

    /* ── CONTENT SECTION ── */
    .cp-content-wrapper {
        background: #ffffff;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 4rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    .cp-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
        align-items: start;
    }

    /* Left: Text */
    .cp-text-col {
    }

    .cp-lead-heading {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
        margin-bottom: 1.5rem;
        border-left: 4px solid #dc2626;
        padding-left: 1rem;
    }

    .cp-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.85;
        margin-bottom: 1.25rem;
    }

    .cp-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 1.75rem 0;
    }

    /* Vessel service tags */
    .cp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .cp-tag {
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        padding: 0.3rem 0.75rem;
        letter-spacing: 0.3px;
    }

    /* Right: Image stack */
    .cp-image-col {
        position: sticky;
        top: 100px;
    }

    .cp-img-main {
        width: 100%;
        border-radius: 12px;
        object-fit: cover;
        height: 320px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        display: block;
    }

    .cp-img-caption {
        font-size: 12px;
        color: #9ca3af;
        text-align: center;
        margin-top: 0.6rem;
        letter-spacing: 0.3px;
    }

    /* Stats row */
    .cp-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
    }

    .cp-stat {
        text-align: center;
    }

    .cp-stat-number {
        font-size: 1.75rem;
        font-weight: 800;
        color: #1a365d;
        line-height: 1;
        display: block;
    }

    .cp-stat-label {
        font-size: 11px;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        font-weight: 500;
        margin-top: 0.3rem;
        display: block;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .cp-hero {
            height: 280px;
        }

        .cp-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .cp-image-col {
            position: static;
        }

        .cp-img-main {
            height: 240px;
        }

        .cp-content-wrapper {
            padding: 2rem 1.25rem 3rem;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="cp-hero">
    <div class="cp-hero-bg"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <p class="cp-breadcrumb">Fleet / Fleet Overview</p>
        <h1 class="cp-hero-title">Fleet Overview</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="cp-content-wrapper">
    <div class="cp-grid">

        <!-- LEFT: Text -->
        <div class="cp-text-col">
            <p class="cp-lead-heading">
                Introducing Our Anchor Handling Tug & Supply Vessels (AHTS)
            </p>

            <hr class="cp-divider" />

            <p class="cp-body-text">
                MV Synergy Explorer and MV Synergy Aurora are state-of-the-art Anchor Handling Tug & Supply Vessels (AHTS) built to deliver reliability, versatility, and strength in offshore operations. Our AHTSs are well-suited for “in-field support” as they are equipped with ample space and deadweight capacity for the carriage of drilling mud, cement, base oil, drill water, and other vital supplies. The stern of each vessel is fitted with a stern roller to facilitate safe and efficient recovery and deployment of anchors, while maintaining a clear area for work wire operations. Beyond anchor handling and towing services, our vessels are also capable of functioning as SSVs (Safety Standby Vessels). They
                are equipped to provide safety standby, rescue operations, and fire-fighting support, as well as oil spill response and recovery efforts — making them highly versatile assets for offshore projects.
            </p>
        </div>

        <!-- RIGHT: Image -->
        <div class="cp-image-col">
            <img src="/images/twinsfleet.png" alt="Synergy Aurora Vessel" class="cp-img-main" />
            <p class="cp-img-caption">MV Synergy Aurora — part of our operational fleet</p>
        </div>

    </div>
</div>
