                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Expected Completion</div>
                            <div class="news-info-value">Q4 2020</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Source</div>
                            <div class="news-info-value">
                                NGV Journal<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">Shin Yang Shipping Corporation</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Back button -->
            <a href="/News/News" class="news-back-btn">
                ← Back to News
            </a>

        </aside>
    </div>
</div>