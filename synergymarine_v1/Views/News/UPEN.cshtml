@{
    ViewData["Title"] = "Malaysia Petroleum Resources Corporation – UPEN";
}

<style>
    /* ── HERO ── */
    .news-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .news-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/synergyexplorer.png') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .news-hero:hover .news-hero-bg {
        transform: scale(1.0);
    }

    .news-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.78) 100%);
    }

    .news-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .news-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

        .news-breadcrumb a {
            color: #60a5fa;
            text-decoration: none;
        }

            .news-breadcrumb a:hover {
                text-decoration: underline;
            }

    .news-hero-title {
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.2;
        margin: 0;
        max-width: 780px;
    }

    /* ── CONTENT WRAPPER ── */
    .news-content-wrapper {
        background: #f9fafb;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 5rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── ARTICLE LAYOUT ── */
    .news-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        align-items: start;
    }

    /* ── ARTICLE MAIN ── */
    .news-article {
        background: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    /* Feature image */
    .news-feature-img-wrap {
        width: 100%;
        height: 420px;
        overflow: hidden;
        position: relative;
        background: #f1f5f9;
    }

    .news-feature-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        transition: transform 6s ease;
    }

    .news-article:hover .news-feature-img {
        transform: scale(1.02);
    }

    /* Category tag over image */
    .news-img-tag {
        position: absolute;
        top: 1.25rem;
        left: 1.25rem;
        background: #1d4ed8;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.35rem 0.85rem;
        border-radius: 20px;
    }

    /* Article body */
    .news-article-body {
        padding: 2rem 2.25rem 2.5rem;
    }

    /* Meta row */
    .news-meta-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .news-meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 500;
    }

    .news-meta-icon {
        font-size: 0.9rem;
    }

    .news-meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    /* Article title */
    .news-article-title {
        font-size: 1.45rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.35;
        margin-bottom: 1.5rem;
        letter-spacing: -0.3px;
    }

    /* Lead paragraph */
    .news-lead {
        font-size: 1rem;
        color: #374151;
        line-height: 1.85;
        font-weight: 500;
        margin-bottom: 1.5rem;
        padding: 1.1rem 1.4rem;
        background: #eff6ff;
        border-left: 4px solid #2563eb;
        border-radius: 0 8px 8px 0;
    }

    .news-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.9;
        margin-bottom: 1.25rem;
    }

    /* Image caption */
    .news-caption {
        font-size: 0.78rem;
        color: #94a3b8;
        text-align: center;
        margin-top: -0.5rem;
        margin-bottom: 1.75rem;
        font-style: italic;
    }

    /* Tags */
    .news-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    .news-tag {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        letter-spacing: 0.3px;
    }

    /* ── SIDEBAR ── */
    .news-sidebar {
        position: sticky;
        top: 100px;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    /* Info card */
    .news-info-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .news-info-card-header {
        background: linear-gradient(135deg, #0f2557, #1e40af);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .news-info-card-header-title {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .news-info-card-body {
        padding: 1.25rem;
    }

    .news-info-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .news-info-row:last-child {
            border-bottom: none;
        }

    .news-info-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
        margin-top: 5px;
    }

    .news-info-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.15rem;
    }

    .news-info-value {
        font-size: 0.83rem;
        color: #1e293b;
        font-weight: 500;
        line-height: 1.45;
    }

    /* Highlight badge card */
    .news-badge-card {
        background: linear-gradient(145deg, #eff6ff, #dbeafe);
        border: 1px solid #bfdbfe;
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
    }

    .news-badge-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
        display: block;
    }

    .news-badge-title {
        font-size: 0.88rem;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 0.3rem;
        line-height: 1.3;
    }

    .news-badge-sub {
        font-size: 0.78rem;
        color: #1d4ed8;
        line-height: 1.5;
    }

    /* Back button */
    .news-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #374151;
        font-size: 0.83rem;
        font-weight: 600;
        padding: 0.6rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        width: 100%;
        justify-content: center;
    }

        .news-back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #374151;
            text-decoration: none;
        }

    /* ── RESPONSIVE ── */
    @@media (max-width: 900px) {
        .news-layout {
            grid-template-columns: 1fr;
        }

        .news-sidebar {
            position: static;
        }

        .news-feature-img-wrap {
            height: 280px;
        }

        .news-hero {
            height: 300px;
        }

        .news-article-body {
            padding: 1.5rem 1.25rem 2rem;
        }
    }

    @@media (max-width: 560px) {
        .news-content-wrapper {
            padding: 2rem 1.25rem 3.5rem;
        }

        .news-feature-img-wrap {
            height: 220px;
        }

        .news-article-title {
            font-size: 1.2rem;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="news-hero">
    <div class="news-hero-bg"></div>
    <div class="news-hero-overlay"></div>
    <div class="news-hero-content">
        <p class="news-breadcrumb">
            <a href="/news">News</a> &nbsp;/&nbsp; Malaysia Petroleum Resources Corporation – UPEN
        </p>
        <h1 class="news-hero-title">Malaysia Petroleum Resources Corporation – UPEN</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="news-content-wrapper">
    <div class="news-layout">

        <!-- ── ARTICLE ── -->
        <article class="news-article">

            <!-- Feature Image -->
            <div class="news-feature-img-wrap">
                <img src="/images/news/UPEN.jpg"
                     alt="Engagement between MPRC, MOGSC and MOSVA with YB Dato' Sri Mustapha Mohamed at UPEN"
                     class="news-feature-img" />
                <span class="news-img-tag">🤝 Industry Engagement</span>
            </div>

            <div class="news-article-body">

                <!-- Meta -->
                <div class="news-meta-row">
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📅</span>
                        <span>September 8, 2022</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🏢</span>
                        <span>Industry &amp; Government Relations</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📍</span>
                        <span>Malaysia</span>
                    </div>
                </div>

                <!-- Title -->
                <h2 class="news-article-title">
                    Synergy Marine Participates in Strategic Engagement Between MPRC, MOGSC, MOSVA and YB Dato' Sri Mustapha Mohamed at UPEN
                </h2>

                <!-- Lead -->
                <p class="news-lead">
                    Synergy Marine (M) Sdn Bhd was represented at a high-level industry engagement session hosted at the Unit Perancang Ekonomi (UPEN), Jabatan Perdana Menteri, on September 8, 2022, bringing together key stakeholders from Malaysia Petroleum Resources Corporation (MPRC), the Malaysian Oil &amp; Gas Services Council (MOGSC), and the Malaysian Offshore Supply Vessel Association (MOSVA).
                </p>

                <p class="news-body-text">
                    The engagement session was convened with YB Dato' Sri Mustapha Mohamed, providing an important platform for industry leaders and marine service providers to align on national petroleum sector priorities, address industry challenges, and strengthen the collaborative framework between government and the offshore oil and gas services community.
                </p>

                <p class="news-body-text">
                    Representatives from MPRC, MOGSC, and MOSVA collectively presented the current landscape of Malaysia's oil and gas services sector, highlighting opportunities for growth, localisation, and the continued development of Malaysian maritime and offshore capabilities. The session underscored the Government's commitment to supporting a resilient and competitive domestic petroleum services industry.
                </p>

                <p class="news-body-text">
                    Synergy Marine's participation in this engagement reflects our commitment to contributing meaningfully to the advancement of Malaysia's oil and gas industry. As a proud Malaysian marine services company, we remain dedicated to working closely with regulatory bodies, industry associations, and government agencies to support the long-term growth and sustainability of the sector.
                </p>

                <!-- Caption -->
                <p class="news-caption">
                    Engagement between MPRC, MOGSC and MOSVA with YB Dato' Sri Mustapha Mohamed at Unit Perancang Ekonomi (UPEN), Jabatan Perdana Menteri.
                </p>

                <!-- Tags -->
                <div class="news-tags">
                    <span class="news-tag">MPRC</span>
                    <span class="news-tag">UPEN</span>
                    <span class="news-tag">MOGSC</span>
                    <span class="news-tag">MOSVA</span>
                    <span class="news-tag">Government Relations</span>
                    <span class="news-tag">Offshore</span>
                    <span class="news-tag">Malaysia</span>
                    <span class="news-tag">2022</span>
                </div>

            </div>
        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="news-sidebar">

            <!-- Engagement Highlight -->
            <div class="news-badge-card">
                <span class="news-badge-icon">🤝</span>
                <div class="news-badge-title">Strategic Industry Engagement</div>
                <div class="news-badge-sub">With YB Dato' Sri Mustapha Mohamed<br />at UPEN, Jabatan Perdana Menteri</div>
            </div>

            <!-- Event Details -->
            <div class="news-info-card">
                <div class="news-info-card-header">
                    <span>📋</span>
                    <div class="news-info-card-header-title">Event Details</div>
                </div>
                <div class="news-info-card-body">

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Date</div>
                            <div class="news-info-value">September 8, 2022</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Type</div>
                            <div class="news-info-value">Industry Engagement Session</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Host</div>
                            <div class="news-info-value">YB Dato' Sri Mustapha Mohamed<br /><span style="color:#94a3b8; font-size:0.75rem;">Unit Perancang Ekonomi (UPEN)</span></div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Participants</div>
                            <div class="news-info-value">MPRC, MOGSC, MOSVA</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Venue</div>
                            <div class="news-info-value">UPEN, Jabatan Perdana Menteri, Malaysia</div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Back button -->
            <a href="/News/News" class="news-back-btn">
                ← Back to News
            </a>

        </aside>
    </div>
</div>
