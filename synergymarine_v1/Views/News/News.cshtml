<script>
    // ── FILTER CONFIG ──
    // Maps each button label to the data-category values it should show
    var filterMap = {
        'All':            ['award', 'press', 'media', 'event', 'company'],
        'Awards':         ['award'],
        'Media Coverage': ['press', 'media'],
        'Company News':   ['company'],
        'Events':         ['event']
    };

    var allCards = document.querySelectorAll('[data-category]');
    var sectionLabels = document.querySelectorAll('.ni-section-label');
    var grids = document.querySelectorAll('.ni-grid, .ni-featured');

    function applyFilter(activeCategories) {
        // Show/hide individual cards with a fade transition
        allCards.forEach(function (card) {
            var cat = card.getAttribute('data-category');
            if (activeCategories.indexOf(cat) !== -1) {
                card.style.display = '';
                card.style.opacity = '0';
                card.style.transform = 'translateY(8px)';
                setTimeout(function () {
                    card.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, 10);
            } else {
                card.style.display = 'none';
            }
        });

        // Hide entire grid containers if all their visible cards are gone
        grids.forEach(function (grid) {
            var visibleCards = Array.from(grid.querySelectorAll('[data-category]')).filter(function (c) {
                return c.style.display !== 'none';
            });
            grid.style.display = visibleCards.length === 0 ? 'none' : '';
        });

        // Hide section labels whose sibling grid is empty
        sectionLabels.forEach(function (label) {
            var next = label.nextElementSibling;
            // Walk forward to find the next grid/featured sibling
            while (next && !next.classList.contains('ni-grid') && !next.classList.contains('ni-featured')) {
                next = next.nextElementSibling;
            }
            if (next) {
                label.style.display = next.style.display === 'none' ? 'none' : '';
            }
        });
    }

    document.querySelectorAll('.ni-filter-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.ni-filter-btn').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            var key = btn.textContent.trim();
            applyFilter(filterMap[key] || filterMap['All']);
        });
    });
</script>
