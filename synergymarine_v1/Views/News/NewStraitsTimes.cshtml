                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Designer</div>
                            <div class="news-info-value">MTCMS Design Sdn Bhd<br /><span style="color:#94a3b8; font-size:0.75rem;">Abdul Razak Ismail, MD &amp; CEO</span></div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Shipyard</div>
                            <div class="news-info-value">Shin Yang Shipyards Sdn Bhd<br /><span style="color:#94a3b8; font-size:0.75rem;">Captain Ting Hien Liong, CEO</span></div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Construction Start</div>
                            <div class="news-info-value">January 2019</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Expected Completion</div>
                            <div class="news-info-value">December 2020</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Photographer</div>
                            <div class="news-info-value">Aswadi Alias</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Source</div>
                            <div class="news-info-value">New Straits Times (NST)</div>
                        </div>
