                    <button class="showreel-play-btn" id="showreelPlayBtn" aria-label="Play company video">
                        <svg class="showreel-play-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 5v14l11-7z" />
                        </svg>
                        <svg class="showreel-pause-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
