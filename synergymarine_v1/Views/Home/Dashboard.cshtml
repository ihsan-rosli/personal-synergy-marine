<script>
    (function () {
        var wrap    = document.getElementById('showreelWrap');
        var video   = document.getElementById('showreelVideo');
        var btn     = document.getElementById('showreelPlayBtn');
        var overlay = document.getElementById('showreelOverlay');

        function togglePlay() {
            if (video.paused) {
                video.play();
                wrap.classList.add('playing');
            } else {
                video.pause();
                wrap.classList.remove('playing');
            }
        }

        btn.addEventListener('click', function (e) { e.stopPropagation(); togglePlay(); });
        overlay.addEventListener('click', togglePlay);
        video.addEventListener('ended', function () { wrap.classList.remove('playing'); });
    })();
</script>


