<!-- ── LIGHTBOX ── -->
<div class="lr-lightbox" id="lrLightbox" onclick="closeLightbox(event)">
    <button class="lr-lightbox-close" onclick="closeLightboxBtn(); event.stopPropagation();">✕</button>
    <img src="" alt="Certificate Preview" class="lr-lightbox-img" id="lrLightboxImg" />
</div>

<script>
    // Read src directly from the thumbnail img inside each card — no duplicate paths needed
    document.querySelectorAll('.lr-lightbox-trigger').forEach(function (card) {
        card.addEventListener('click', function () {
            var imgEl = card.querySelector('.lr-lightbox-img-src');
            if (!imgEl) return;
            var lb    = document.getElementById('lrLightbox');
            var lbImg = document.getElementById('lrLightboxImg');
            lbImg.src = imgEl.src;          // uses the already-resolved absolute URL
            lb.classList.add('active');
            document.body.style.overflow = 'hidden';
        });
    });

    function closeLightboxBtn() {
        var lb = document.getElementById('lrLightbox');
        lb.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Click the dark backdrop to close
    document.getElementById('lrLightbox').addEventListener('click', function (e) {
        if (e.target === this) closeLightboxBtn();
    });

    // Esc key to close
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeLightboxBtn();
    });
</script>
