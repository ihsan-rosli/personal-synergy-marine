@{
    ViewData["Title"] = "Vision & Mission";
}

<style>
    /* ── HERO SECTION ── */
    .cp-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .cp-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/image slide 3.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .cp-hero:hover .cp-hero-bg {
        transform: scale(1.0);
    }

    .cp-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.75) 100%);
    }

    .cp-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .cp-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

    .cp-hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin: 0;
    }

    /* ── CONTENT SECTION ── */
    .cp-content-wrapper {
        background: #ffffff;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 4rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    .cp-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
        align-items: start;
    }

    .cp-lead-heading {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
        margin-bottom: 1.5rem;
        border-left: 4px solid #dc2626;
        padding-left: 1rem;
    }

    .cp-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.85;
        margin-bottom: 1.25rem;
    }

    .cp-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 1.75rem 0;
    }

    /* Vision / Mission blocks */
    .vm-block {
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.75rem;
        margin-bottom: 1.5rem;
    }

    .vm-block-icon {
        font-size: 1.5rem;
        margin-bottom: 0.75rem;
    }

    .vm-block-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a365d;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .vm-block-title span.badge-label {
            background: #dc2626;
            color: #fff;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            border-radius: 4px;
            padding: 0.2rem 0.6rem;
        }

    .vm-block-text {
        font-size: 0.92rem;
        color: #4b5563;
        line-height: 1.85;
        margin: 0;
    }

    /* Right: image */
    .cp-image-col {
        position: sticky;
        top: 100px;
    }

    .cp-img-main {
        width: 100%;
        border-radius: 12px;
        object-fit: cover;
        height: 320px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        display: block;
    }

    .cp-img-caption {
        font-size: 12px;
        color: #9ca3af;
        text-align: center;
        margin-top: 0.6rem;
        letter-spacing: 0.3px;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .cp-hero {
            height: 280px;
        }

        .cp-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .cp-image-col {
            position: static;
        }

        .cp-img-main {
            height: 240px;
        }

        .cp-content-wrapper {
            padding: 2rem 1.25rem 3rem;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="cp-hero">
    <div class="cp-hero-bg"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <p class="cp-breadcrumb">About Us / Vision & Mission</p>
        <h1 class="cp-hero-title">Vision & Mission</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="cp-content-wrapper">
    <div class="cp-grid">

        <!-- LEFT: Text -->
        <div class="cp-text-col">
            <p class="cp-lead-heading">
                Our Strategic Direction & Commitment define the path we follow and the values we uphold to achieve sustainable growth
            </p>

          

            <hr class="cp-divider" />

            <!-- Vision Block -->
            <div class="vm-block">
                <div class="vm-block-title">
                    <span>🔭</span>
                    <span class="badge-label">Vision</span>
                </div>
                <p class="vm-block-text">
                    The Company aspires to be the most preferred provider of offshore support vessel that meets
                    approved quality standards in the market in which we compete.
                </p>
            </div>

            <!-- Mission Block -->
            <div class="vm-block">
                <div class="vm-block-title">
                    <span>🎯</span>
                    <span class="badge-label">Mission</span>
                </div>
                <p class="vm-block-text">
                    The Company will provide superior quality service and make a contribution to the success of
                    the business, customers and communities we support. We will achieve our mission by providing
                    timely, accurate and professional service at each and every customer contact. The Company
                    aspires to be the most preferred provider of offshore support vessel that meets approved
                    quality standards in the market in which we compete.
                </p>
            </div>
        </div>

        <!-- RIGHT: Image -->
        <div class="cp-image-col">
            <img src="/images/synergyaurora.png" alt="Synergy Aurora Vessel" class="cp-img-main" />
            <p class="cp-img-caption">MV Synergy Aurora — part of our operational fleet</p>

            <!-- Client Satisfaction Rating -->
            <div style="text-align: center; padding: 2rem 1rem 1rem;">
                <p style="font-size: 0.78rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #dc2626; margin-bottom: 0.5rem;">Client Satisfaction</p>
                <div style="display: flex; justify-content: center; gap: 6px; margin-bottom: 0.75rem;">
                    @for (int i = 0; i < 5; i++)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24"
                             fill="#f59e0b">
                            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                        </svg>
                    }
                </div>
                <p style="font-size: 3rem; font-weight: 800; color: #1e293b; line-height: 1; margin-bottom: 0.25rem;">5.0 <span style="font-size: 1rem; font-weight: 500; color: #9ca3af;">/ 5.0</span></p>
                <p style="font-size: 0.88rem; color: #6b7280; margin-top: 0.5rem;">Rated by our clients for service excellence<br />and vessel reliability.</p>
            </div>
        </div>

    </div>
</div>
