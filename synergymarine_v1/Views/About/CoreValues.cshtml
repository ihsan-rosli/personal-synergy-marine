@{
    ViewData["Title"] = "Core Values";
}

<style>
    /* ── HERO SECTION ── */
    .cp-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .cp-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/image slide 1.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .cp-hero:hover .cp-hero-bg {
        transform: scale(1.0);
    }

    .cp-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.75) 100%);
    }

    .cp-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .cp-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

    .cp-hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin: 0;
    }

    /* ── CONTENT WRAPPER ── */
    .cp-content-wrapper {
        background: #ffffff;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 4rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── TOP GRID: left text+icons / right image ── */
    .val-top-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
        align-items: start;
        margin-bottom: 2.5rem;
    }

    /* ── HEADING ── */
    .val-heading {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
        margin-bottom: 2rem;
        border-left: 4px solid #dc2626;
        padding-left: 1rem;
    }

    /* ── VALUES ICON GRID ── */
    .val-icons-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem 1rem;
    }

    .val-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .val-icon-circle {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: #f8fafc;
        border: 1.5px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.85rem;
        transition: all 0.3s ease;
    }

    .val-item:hover .val-icon-circle {
        background: #eff6ff;
        border-color: #bfdbfe;
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(37,99,235,0.1);
    }

    .val-icon-circle svg {
        width: 38px;
        height: 38px;
        stroke: #1a365d;
        fill: none;
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        transition: stroke 0.3s ease;
    }

    .val-item:hover .val-icon-circle svg {
        stroke: #dc2626;
    }

    .val-label {
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
        line-height: 1.3;
    }

    /* ── RIGHT IMAGE ── */
    .val-image-col {
        position: sticky;
        top: 100px;
    }

    .val-img-main {
        width: 100%;
        border-radius: 12px;
        object-fit: cover;
        height: 380px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        display: block;
    }

    /* ── BOTTOM DESCRIPTION ── */
    .cp-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 0 0 2rem;
    }

    .val-desc {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.85;
        max-width: 860px;
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 768px) {
        .cp-hero {
            height: 280px;
        }

        .val-top-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }

        .val-image-col {
            position: static;
        }

        .val-img-main {
            height: 260px;
        }

        .val-icons-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .val-icon-circle {
            width: 72px;
            height: 72px;
        }

            .val-icon-circle svg {
                width: 30px;
                height: 30px;
            }

        .cp-content-wrapper {
            padding: 2rem 1.25rem 3rem;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="cp-hero">
    <div class="cp-hero-bg"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <p class="cp-breadcrumb">About Us / Core Values</p>
        <h1 class="cp-hero-title">Our Core Values</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="cp-content-wrapper">

    <div class="val-top-grid">

        <!-- LEFT: Heading + Icons -->
        <div>
            <p class="val-heading">
                Driven by customer satisfaction, powered by passion, and strengthened through teamwork
            </p>

            <div class="val-icons-grid">

                <!-- Teamwork -->
                <div class="val-item">
                    <div class="val-icon-circle">
                        <svg viewBox="0 0 24 24"><circle cx="9" cy="7" r="3" /><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /><path d="M21 21v-2a4 4 0 0 0-3-3.85" /></svg>
                    </div>
                    <span class="val-label">Teamwork</span>
                </div>

                <!-- Commitment -->
                <div class="val-item">
                    <div class="val-icon-circle">
                        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                    </div>
                    <span class="val-label">Commitment</span>
                </div>

                <!-- Efficiency -->
                <div class="val-item">
                    <div class="val-icon-circle">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    </div>
                    <span class="val-label">Efficiency</span>
                </div>

                <!-- Passion -->
                <div class="val-item">
                    <div class="val-icon-circle">
                        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                    </div>
                    <span class="val-label">Passion</span>
                </div>

                <!-- Integrity -->
                <div class="val-item">
                    <div class="val-icon-circle">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    </div>
                    <span class="val-label">Integrity</span>
                </div>

                <!-- Customer Service Satisfaction -->
                <div class="val-item">
                    <div class="val-icon-circle">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></svg>
                    </div>
                    <span class="val-label">Customer Service Satisfaction</span>
                </div>

            </div>
        </div>

        <!-- RIGHT: Image -->
        <div class="val-image-col">
            <img src="/images/synergyoffice.jpg" alt="Synergy Marine Office" class="val-img-main" />
        </div>

    </div>

    <!-- Bottom description -->
    <hr class="cp-divider" />
    <p class="val-desc">
        We are driven by customer service satisfaction, delivering efficient and reliable vessel operations through
        passion, teamwork, and strong commitment. Our empowered team ensures safe, timely, and seamless support
        for offshore operations, including AHTS and Platform Supply Vessel services.
    </p>

</div>
